{
  "name": "@sokil/api",
  "version": "0.1.10",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "test": "jest",
    "test:run": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:integration": "jest --config ./test/jest-integration.json",
    "mikro-orm": "mikro-orm",
    "migration:clear": "rm -f src/migrations/Migration*.ts src/migrations/.snapshot*.json dist/src/migrations/Migration*.js dist/src/migrations/Migration*.js.map dist/src/migrations/Migration*.d.ts dist/src/migrations/.snapshot*.json",
    "migration:clear-db-history": "docker compose exec db sh -c 'psql -U archery_user -d archery_db -c \"TRUNCATE TABLE mikro_orm_migrations;\"'",
    "migration:baseline-feb2026": "docker compose exec -T db psql -U archery_user -d archery_db -c \"INSERT INTO mikro_orm_migrations (name, executed_at) SELECT v.name, NOW() FROM (VALUES ('Migration20260217144407'), ('Migration20260223154857'), ('Migration20260223170403')) AS v(name) WHERE NOT EXISTS (SELECT 1 FROM mikro_orm_migrations m WHERE m.name = v.name);\"",
    "migration:initial": "mikro-orm migration:create --initial",
    "generate-pdf-icons": "ts-node scripts/generate-pdf-icons.ts"
  },
  "dependencies": {
    "@mikro-orm/core": "^6.6.12",
    "@mikro-orm/migrations": "^6.6.12",
    "@mikro-orm/nestjs": "^6.1.2",
    "@mikro-orm/postgresql": "^6.6.12",
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^11.1.18",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@sokil/shared-configs": "workspace:*",
    "@sokil/shared-types": "workspace:*",
    "@types/nodemailer": "^6.4.23",
    "bcryptjs": "^2.4.3",
    "class-transformer": "0.5.1",
    "class-validator": "^0.14.4",
    "cookie-parser": "^1.4.7",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.0",
    "helmet": "^8.3.0",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.17.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.35.0",
    "uuid": "^11.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@mikro-orm/cli": "^6.6.12",
    "@mikro-orm/seeder": "^6.6.12",
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^11.1.18",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.15.0",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdfkit": "^0.17.5",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.13.0"
}
