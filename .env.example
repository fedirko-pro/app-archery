# Sokil monorepo — single environment file (copy to .env at repo root)

# --- Database (API + docker compose db service) ---
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=archery_user
DATABASE_PASSWORD=archery_password
DATABASE_NAME=archery_db

# --- API ---
PORT=3000
JWT_SECRET=supersecret
GOOGLE_CLIENT_ID=dummy_google_client_id
GOOGLE_CLIENT_SECRET=dummy_google_client_secret
FRONTEND_URL=http://localhost:3001
BACKEND_URL=http://localhost:3000
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# SMTP — see apps/api/docs/EMAIL_SETUP.md
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USER=your-email@zoho.com
SMTP_PASSWORD=your-zoho-password-or-app-password
SMTP_FROM_EMAIL=your-email@zoho.com
SMTP_FROM_NAME=Archery App

# --- Web (NEXT_PUBLIC_* are baked into the client bundle at build time) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_GOOGLE_AUTH_URL=http://localhost:3000/auth/google
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Optional: server-side fetches in Next.js (defaults to http://localhost:3000)
# API_INTERNAL_URL=http://localhost:3000
