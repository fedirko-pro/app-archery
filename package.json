{
  "name": "sokil",
  "version": "0.1.10",
  "private": true,
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @sokil/web --filter @sokil/api dev",
    "dev:web": "pnpm --filter @sokil/web dev",
    "dev:api": "pnpm --filter @sokil/api dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm --filter @sokil/web typecheck && pnpm --filter @sokil/api typecheck",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=9.0.0"
  }
}
